{
  "manifest_version": 3,
  "name": "Deliveroo Reset - TFX (EXTREME)",
  "version": "2.11",
  "description": "MADE BY TFX — EXTREME",
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": [
    "cookies",
    "browsingData",
    "storage",
    "declarativeNetRequest",
    "alarms"
  ],
  "host_permissions": [
    "https://*.deliveroo.co.uk/*",
    "https://*.deliveroo.com/*",
    "https://roo-proxy.nexaserve.uk/*",
    "https://roo-proxy-server-production.up.railway.app/*",
    "https://dashboard.nexaserve.uk/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["logo.png", "nexaserve-logo.png", "applepay-sdk.js", "applepay-button.svg", "deliveroo-theme.js", "popup.html", "popup.js", "icon16.png", "icon32.png", "icon48.png", "icon128.png"],
      "matches": ["https://*.deliveroo.co.uk/*", "https://*.deliveroo.com/*"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["https://*.deliveroo.co.uk/*", "https://*.deliveroo.com/*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": ["https://dashboard.nexaserve.uk/*"],
      "js": ["sitelink.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Deliveroo Reset - TFX",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  }
}
